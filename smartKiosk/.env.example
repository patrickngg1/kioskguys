# Backend environment variables — copy to .env and fill in real values
# These are set in the Render dashboard for the backend service.

# Django
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=kioskguys.onrender.com
CORS_ALLOWED_ORIGINS=https://kioskguys-front.onrender.com
CSRF_TRUSTED_ORIGINS=https://kioskguys-front.onrender.com,https://kioskguys.onrender.com

# Database (TiDB)
DB_NAME=test
DB_USER=replace
DB_PASSWORD=replace
DB_HOST=gateway01.us-east-1.prod.aws.tidbcloud.com
DB_PORT=4000

# Email (Amazon SES SMTP)
SES_SMTP_USER=replace
SES_SMTP_PASS=replace

# Frontend build env (set in Render frontend service)
# VITE_API_BASE_URL=https://kioskguys.onrender.com
